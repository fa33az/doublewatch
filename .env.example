# DoubleWatch - Environment Variables Configuration
# Copy this file to .env.local to configure your own keys:
# cp .env.example .env.local

# Official YouTube Data API v3 Key (Optional)
# If provided, DoubleWatch will fetch search results and live streaming metrics via Google's official API.
# If omitted, it will automatically fall back to the built-in, quota-free scraper!
YOUTUBE_API_KEY=your_official_youtube_api_key_here
